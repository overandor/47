{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo47.example/control/unchained/schemas/entry.schema.json",
  "title": "Unchained Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "text",
    "languages",
    "mix_mode",
    "style",
    "media_file",
    "external_ref"
  ],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "text": { "type": "string", "minLength": 1 },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "mix_mode": {
      "type": "string",
      "enum": ["bilingual", "trilingual", "code-switch", "hybrid-poetic"]
    },
    "style": {
      "type": "string",
      "enum": ["artifact", "ritual", "archive", "signal", "glitch", "oracle"]
    },
    "media_file": { "type": "string", "pattern": "^media/.+" },
    "external_ref": { "type": "string", "minLength": 1 }
  }
}
